# ============================================================
# ORION MARKET AI — .gitignore
# ============================================================

# ─── Environment & Secrets ───────────────────────────────────
.env
*.env
.env.*
!.env.example

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.pdb
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-log.txt

# ─── Virtual Environment ─────────────────────────────────────
venv/
env/
.venv/
ENV/
virtualenv/

# ─── Django ──────────────────────────────────────────────────
*.sqlite3
orion_db.sqlite3
orion_debug.log
staticfiles/
static_root/
media/
*.log
local_settings.py

# ─── Node / React ────────────────────────────────────────────
node_modules/
frontend/build/
frontend/dist/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
frontend/coverage/

# ─── Vector DB ───────────────────────────────────────────────
chroma_db/
faiss_index/
vectorstore/
*.faiss
*.index

# ─── ML Models & Cache ───────────────────────────────────────
.cache/
huggingface/
*.bin
*.safetensors
*.pt
*.pth
*.h5
*.pkl
*.pickle
*.joblib
models/
checkpoints/

# ─── Testing ─────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
junit.xml
test-results/
nosetests.xml

# ─── PM2 / Logs ──────────────────────────────────────────────
logs/
*.pid
*.pid.lock
.pm2/

# ─── Docker ──────────────────────────────────────────────────
.docker/
docker-compose.override.yml

# ─── OS Files ────────────────────────────────────────────────
.DS_Store
.AppleDouble
Thumbs.db
Thumbs.db:encryptable
desktop.ini
Desktop.ini
$RECYCLE.BIN/
._*

# ─── IDE ─────────────────────────────────────────────────────
.vscode/
.idea/
*.iml
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ─── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
*.orig
*.zip
*.tar.gz

# ─── Keep These ──────────────────────────────────────────────
!.env.example
!requirements.txt
!README.md